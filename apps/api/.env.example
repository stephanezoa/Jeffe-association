# Configuration Environnement VESTIGE
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1

# Base de données (DB_CLIENT=sqlite3 | pg)
DB_CLIENT=sqlite3
DB_FILENAME=./data/vestige.dev.sqlite

# Pour PostgreSQL (DB_CLIENT=pg)
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=vestige_user
# DB_PASSWORD=vestige_secret
# DB_NAME=vestige_db
# DB_SSL=false

# Authentification JWT
JWT_ACCESS_SECRET=super-secret-access-key-change-in-production-32chars
JWT_REFRESH_SECRET=super-secret-refresh-key-change-in-production-32chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Logging & Audit
LOG_LEVEL=info

# HMAC secret pour QR code billets
QR_HMAC_SECRET=vestige-qr-signing-secret-key-32chars
